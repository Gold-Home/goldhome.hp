# ============================================
# Gemini API キー設定ファイル（テンプレート）
# ============================================
#
# ⚠️ このファイルはテンプレートです。実際のキーは含めていません。
#
# 【使い方】
# 1. このファイルと同じ場所（scripts/フォルダ）に、
#    名前を「.env」（先頭がドットのみ）としてコピーしてください
# 2. 下の GEMINI_API_KEY= のあとに、
#    https://aistudio.google.com/apikey で取得したキーを貼り付け
# 3. 保存してください
#
# 【注意】
# - .env は .gitignore で Git 管理外に設定済み → GitHub にアップされません
# - このファイル（.env.example）はダミー値のみ含み、コミット可
# - キーは AIzaSy で始まる文字列です
# ============================================

GEMINI_API_KEY=ここにあなたのAPIキーを貼り付けてください

# 使用モデル（変更不要）
# gemini-3.1-flash-image = Gemini 3.1 Flash Image（推奨・GA）
# gemini-3-pro-image     = Gemini 3 Pro Image（最高品質）
# imagen-4.0-generate-001 = Imagen 4（有料・別APIエンドポイント）
GEMINI_MODEL=gemini-3.1-flash-image
